const { album } = Astro.props;
const images = await getAlbumImages(album.id, album.data.imagesFolder);
---
<Layout>
  <div class="text-center my-16 mb-32 max-w-6xl mx-auto">
    <h1 class="text-3xl xl:text-6xl font-bold">{album.data.title}</h1>
    <p class="text-lg xl:text-2xl my-4">{album.data.description}</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 my-8">
      {images.map((image) => (
        <a href={image.src} target="_blank" rel="noopener noreferrer" class="group transition-all hover:scale-105">
          <img
            src={image.src}
            alt={image.alt}
            width={400}
            height={400}
            class="rounded-lg object-cover aspect-square"
            loading="lazy"
          />
        </a>
      ))}
    </div>

    <p class="text-lg my-4 text-center">
      <a href="/gallery/" class="text-primary hover:underline">
        ← Back to Gallery
      </a>
    </p>
  </div>
</Layout>;
